<section class="spotlight spotlight--directory tile" id="spot-directory" role="region" aria-label="Direktori">
  
  <div class="directory-header" style="display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-sm); flex-shrink: 0; width: 100%; margin-bottom: var(--space-md);">
    <a href="skills.html" class="blog-slider__title-link" id="directoryTitle">
      DIREKTORI
    </a>
    
    <div class="directory-toolbar" style="display: flex; align-items: center; justify-content: flex-start; gap: var(--space-sm); width: 100%; flex-wrap: wrap;">
      <div class="directory-tabs" role="tablist" aria-label="Filter direktori">
        <button class="directory-tab directory-tab--active" role="tab" aria-selected="true" data-filter="all">SEMUA</button>
        <button class="directory-tab" role="tab" aria-selected="false" data-filter="skill">SKILL</button>
        <button class="directory-tab" role="tab" aria-selected="false" data-filter="design">DESIGN</button>
        <button class="directory-tab" role="tab" aria-selected="false" data-filter="mcp">MCP</button>
      </div>
      
      <div class="directory-search-wrapper">
        <input type="text" id="directorySearch" placeholder="CARI..." aria-label="Cari direktori...">
      </div>
    </div>
  </div>

  {# ── Rotating Stage ── #}
  <div class="spotlight__stage" id="directoryStage" aria-live="off" style="flex: 1; min-height: 0; position: relative;">
    {%- for item in collections.directory %}
      <article class="slide directory-slide" data-slide-index="{{ loop.index0 }}" data-type="{{ item.type }}" data-title="{{ item.title | lower }}" data-desc="{{ item.description | lower }}" data-url="{{ item.url }}" style="display: none; height: 100%;">
        <div class="slide__content" style="height: 100%; display: flex; flex-direction: column;">
          
          {# Badge & Category #}
          <div class="tile-label slide__label" style="text-transform: uppercase; margin-bottom: var(--space-sm);">
            <span class="directory-item__badge directory-item__badge--{{ item.type }}" style="margin-right: var(--space-xs); font-family: 'Space Mono', monospace; font-size: 9px; font-weight: 700; padding: 1px 6px; border-radius: 3px;">{{ item.type | upper }}</span>
            {{ item.category | h }}
          </div>

          {# Slide Body #}
          <div class="slide__body" style="flex: 1; display: flex; flex-direction: column;">
            <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: var(--heading); font-weight: 500; line-height: 1.3; margin-bottom: var(--space-xs); color: var(--text-display); text-transform: capitalize;">
              {{ item.title | h }}
            </h2>

            <p style="font-family: 'Space Grotesk', sans-serif; font-size: var(--body-sm); color: var(--text-secondary); line-height: 1.45; max-width: 60ch; margin-bottom: var(--space-md);">
              {{ item.description | h }}
            </p>
          </div>

        </div>
      </article>
    {%- endfor %}
  </div>

  {# ── Controls ── #}
  <div class="spotlight__controls" id="directoryControls" role="group" aria-label="Directory slides controls" style="display: flex; justify-content: space-between; width: 100%; align-items: center; margin-top: var(--space-md); flex-wrap: wrap; gap: var(--space-md);">
    <div style="display: flex; align-items: center; gap: var(--space-sm);">
      <button class="spot-btn spot-btn--prev" id="dirPrev" type="button" aria-label="Previous directory item">‹</button>
      <div class="spot-dots" id="dirDots" role="tablist" aria-label="Directory slides">
        {# Dynamic dots #}
      </div>
      <button class="spot-btn spot-btn--next" id="dirNext" type="button" aria-label="Next directory item">›</button>
    </div>
    
    <div style="display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap;">
      <a href="skills.html" id="directoryAllCta" style="font-family: 'Space Mono', monospace; font-size: var(--label); letter-spacing: 0.06em; color: var(--text-secondary); text-decoration: none; text-transform: uppercase;" class="touch-primary">
        LIHAT SEMUA SKILL.MD ↗
      </a>
      
      <a href="#" id="directoryReadMoreBtn" class="arrow-pill arrow-pill--accent" style="flex-shrink: 0;">
        <span>BACA SELENGKAPNYA</span>
        <span class="arrow-pill__arrow">→</span>
      </a>
    </div>
  </div>

</section>
