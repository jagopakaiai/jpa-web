<section class="tile tile-hero" aria-label="{{ site.siteName | h }} Hero">
      <div class="tile-hero__label">{{ hero.label | h }}</div>
      <h1 class="tile-hero__title">{{ hero.title | h }}</h1>
      <p class="tile-hero__subtitle">{{ hero.subtitle | h }}</p>
      <p class="tile-hero__desc">{{ hero.description | h }}</p>
      <a href="{{ hero.ctaHref }}" class="btn-primary tile-hero__cta">{{ hero.ctaText | h }}</a>
    </section>
