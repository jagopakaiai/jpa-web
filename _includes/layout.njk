<!DOCTYPE html>
<html lang="en" dir="ltr" data-theme="dark"{% if zoom %} data-zoom="{{ zoom }}"{% endif %}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | h }}</title>
  <meta name="description" content="{{ description | h }}">
  <link rel="icon" type="image/png" href="/favicon.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Doto:wght@400;700&family=Space+Grotesk:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
{% block head %}{% endblock %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
{% block body %}{% endblock %}
  <!-- JOE AI Agent Chat Trigger Button (Global Floating) -->
  <button id="joeChatTrigger" class="joe-chat-trigger" type="button" aria-label="Chat dengan JOE AI Agent">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
  </button>

  <!-- JOE AI Chat Dialog Window (Popup on the Left) -->
  <div id="joeChatWindow" class="joe-chat-window" style="display: none;">
    <div class="joe-chat-header">
      <div style="display: flex; align-items: center; gap: var(--space-sm);">
        <div class="joe-avatar">JOE</div>
        <div>
          <div class="joe-name">JOE</div>
          <div class="joe-status">AI Agent Assistant</div>
        </div>
      </div>
      <button id="joeChatClose" class="joe-chat-close" type="button" aria-label="Tutup chat">&times;</button>
    </div>
    
    <div id="joeChatMessages" class="joe-chat-messages">
      <div class="joe-message joe-message--assistant">
        Halo! Saya <strong>JOE</strong>, AI Agent Assistant untuk JagoPakaiAI. Ada yang bisa saya bantu?
      </div>
    </div>
    
    <form id="joeChatForm" class="joe-chat-form">
      <input type="text" id="joeChatInput" placeholder="Tanya JOE..." required autocomplete="off">
      <button type="submit" aria-label="Kirim pesan">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </form>
  </div>

  <script>
    (function() {
      var trigger = document.getElementById('joeChatTrigger');
      var win = document.getElementById('joeChatWindow');
      var closeBtn = document.getElementById('joeChatClose');
      var form = document.getElementById('joeChatForm');
      var input = document.getElementById('joeChatInput');
      var msgsContainer = document.getElementById('joeChatMessages');
      var chatHistory = [];

      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        if (win.style.display === 'none') {
          win.style.display = 'flex';
          input.focus();
        } else {
          win.style.display = 'none';
        }
      });

      closeBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        win.style.display = 'none';
      });

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        e.stopPropagation();
        var text = input.value.trim();
        if (!text) return;

        // Add user message
        appendMessage('user', text);
        input.value = '';
        chatHistory.push({ role: 'user', content: text });

        // Add loading message
        var loadingId = appendMessage('assistant', '...', true);

        try {
          // Attempt Netlify function first (ideal for production / Netlify Dev local CLI)
          var response = await fetch('/.netlify/functions/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ messages: chatHistory })
          });
          
          if (!response.ok) throw new Error('Netlify function not available');
          
          var data = await response.json();
          var reply = data.choices[0].message.content;
          
          // Remove loading and show actual reply
          removeLoadingMessage(loadingId);
          appendMessage('assistant', reply);
          chatHistory.push({ role: 'assistant', content: reply });
        } catch (err) {
          console.warn('Netlify function failed, falling back to client-side direct Groq query:', err);
          
          var localKey = localStorage.getItem('groq-api-key');
          if (!localKey) {
            removeLoadingMessage(loadingId);
            appendMessage('assistant', 'Gagal menghubungi serverless function. Untuk menggunakan chat JOE secara realtime di localhost, silakan masukkan Groq API Key Anda (disimpan aman di browser Anda):');
            appendInlineApiKeyInput();
            return;
          }

          // Directly call Groq API from client-side
          try {
            var directResponse = await fetch('https://api.groq.com/openai/v1/chat/completions', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + localKey
              },
              body: JSON.stringify({
                model: 'llama-3.3-70b-versatile',
                messages: [
                  {
                    role: 'system',
                    content: `Anda adalah JOE, AI Agent Assistant untuk JPA (JagoPakaiAI) Hub di jpa.my.id.
Jawablah dengan ramah, profesional, dan dalam bahasa Indonesia.
Bantu user merencanakan proyek AI Agent mereka dengan memberikan rekomendasi link direktif yang relevan (SKILL.MD, DESIGN.MD, MCP Server).
Gunakan format Markdown link berikut secara akurat:
- SKILL.MD: /skills.html#<kategori> (kategori: coding, devops, design, data, writing, productivity)
- DESIGN.MD: /designs.html
- MCP Server: /mcps.html`
                  },
                  ...chatHistory
                ]
              })
            });

            if (!directResponse.ok) {
              if (directResponse.status === 401) {
                localStorage.removeItem('groq-api-key');
                throw new Error('API Key tidak valid (401). Silakan coba kirim ulang pesan untuk memasukkan key baru.');
              }
              throw new Error('Groq API Error: ' + directResponse.status);
            }

            var directData = await directResponse.json();
            var reply = directData.choices[0].message.content;

            removeLoadingMessage(loadingId);
            appendMessage('assistant', reply);
            chatHistory.push({ role: 'assistant', content: reply });
          } catch (directErr) {
            removeLoadingMessage(loadingId);
            appendMessage('assistant', 'Gagal memanggil Groq: ' + directErr.message);
          }
        }
      });

      function appendInlineApiKeyInput() {
        var container = document.createElement('div');
        container.className = 'joe-message joe-message--assistant';
        container.style.cssText = 'display: flex; flex-direction: column; gap: 8px; width: 85%; margin-top: 4px; box-sizing: border-box;';

        var keyInput = document.createElement('input');
        keyInput.type = 'password';
        keyInput.placeholder = 'gsk_...';
        keyInput.style.cssText = 'width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #E4E4E7; font-size: 12px; background: #FFFFFF; color: #18181B; box-sizing: border-box;';

        var saveBtn = document.createElement('button');
        saveBtn.textContent = 'Simpan API Key';
        saveBtn.style.cssText = 'padding: 8px 12px; background: #18181B; color: #FFFFFF; border: none; border-radius: 6px; font-size: 12px; font-weight: bold; cursor: pointer; transition: opacity 150ms ease;';
        saveBtn.addEventListener('mouseover', function() { saveBtn.style.opacity = '0.9'; });
        saveBtn.addEventListener('mouseout', function() { saveBtn.style.opacity = '1'; });

        saveBtn.addEventListener('click', function() {
          var val = keyInput.value.trim();
          if (val) {
            localStorage.setItem('groq-api-key', val);
            container.remove();
            appendMessage('assistant', 'API Key tersimpan! Silakan ketik pesan Anda kembali untuk memulai chat.');
          }
        });

        container.appendChild(keyInput);
        container.appendChild(saveBtn);
        msgsContainer.appendChild(container);
        msgsContainer.scrollTop = msgsContainer.scrollHeight;
      }

      function appendMessage(sender, text, isLoading = false) {
        var msg = document.createElement('div');
        msg.className = 'joe-message joe-message--' + sender;
        if (isLoading) {
          msg.id = 'loading-' + Date.now();
          msg.innerHTML = '<span class="loading-dots"><span>.</span><span>.</span><span>.</span></span>';
        } else {
          // Simple markdown-to-HTML formatting for bold and line breaks
          var formatted = text
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.*?)\*/g, '<em>$1</em>')
            .replace(/\n/g, '<br>');
          msg.innerHTML = formatted;
        }
        msgsContainer.appendChild(msg);
        msgsContainer.scrollTop = msgsContainer.scrollHeight;
        return msg.id;
      }

      function removeLoadingMessage(id) {
        var el = document.getElementById(id);
        if (el) el.remove();
      }
    })();
  </script>
</body>
</html>
