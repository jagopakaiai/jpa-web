{% extends "layout.njk" %}

{% set title = "CIM Launch Event — April 27, 2026" %}
{% set description = "Center for Interactive Media launch event at Kennesaw State University — demos, research showcase, panels on the future of interactive media." %}

{% block head %}
  <script>
    // Prevent FOUC: apply saved theme before first paint
    (function(){
      var t=localStorage.getItem('cim-theme');if(t)document.documentElement.setAttribute('data-theme',t);
    })();
  </script>
  <style>
    /* Shared tokens — same as main site */
    [data-theme="dark"], :root {
      --black: #000000;
      --surface: #111111;
      --surface-raised: #1A1A1A;
      --border: #222222;
      --border-visible: #333333;
      --text-disabled: #666666;
      --text-secondary: #999999;
      --text-primary: #E8E8E8;
      --text-display: #FFFFFF;
      --accent: #D71921;
      --accent-subtle: rgba(215, 25, 33, 0.15);
      --success: #4A9E5C;
      --warning: #D4A843;
      --interactive: #5B9BF6;
      --space-xs: 4px; --space-sm: 8px; --space-md: 16px;
      --space-lg: 24px; --space-xl: 32px; --space-2xl: 48px;
      --space-3xl: 64px; --space-4xl: 96px;
      --display-xl: clamp(56px, min(7vw, 12vh), 132px);
      --display-lg: clamp(40px, min(4.8vw, 8vh),  92px);
      --display-md: clamp(32px, min(3.4vw, 5.8vh), 64px);
      --heading:    clamp(22px, min(2.1vw, 3.5vh), 40px);
      --subheading: clamp(18px, min(1.6vw, 2.7vh), 30px);
      --body:       clamp(15px, min(1.15vw, 1.9vh), 22px);
      --body-sm:    clamp(14px, min(1vw,    1.7vh), 19px);
      --caption:    clamp(13px, min(0.85vw, 1.4vh), 17px);
      --label:      clamp(12px, min(0.75vw, 1.25vh), 15px);
    }

    [data-theme="light"] {
      --black: #F5F5F5; --surface: #FFFFFF; --surface-raised: #F0F0F0;
      --border: #E8E8E8; --border-visible: #CCCCCC;
      --text-disabled: #999999; --text-secondary: #666666;
      --text-primary: #1A1A1A; --text-display: #000000;
      --interactive: #007AFF;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { font-size: 16px; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }

    body {
      font-family: 'Space Grotesk', system-ui, sans-serif;
      background: var(--black);
      color: var(--text-primary);
      min-height: 100vh;
    }

    /* Desktop: full viewport, no scroll */
    .event-page {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr;
    }

    /* Left panel: hero */
    .event-hero {
      background: var(--surface);
      border-right: 1px solid var(--border);
      padding: var(--space-3xl);
      padding-top: var(--space-4xl);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      position: relative;
    }

    .event-hero__back {
      position: absolute;
      top: var(--space-lg);
      left: var(--space-lg);
      z-index: 50;
    }

    .event-hero__label {
      font-family: 'Space Mono', monospace;
      font-size: var(--label);
      letter-spacing: 0.12em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: var(--space-lg);
    }

    .event-hero__date {
      font-family: 'Doto', 'Space Mono', monospace;
      font-size: clamp(56px, 8vw, 112px);
      font-weight: 700;
      line-height: 0.9;
      letter-spacing: -0.04em;
      color: var(--text-display);
      margin-bottom: var(--space-sm);
    }

    .event-hero__year {
      font-family: 'Doto', 'Space Mono', monospace;
      font-size: clamp(24px, 3vw, 40px);
      font-weight: 700;
      color: var(--text-secondary);
      letter-spacing: -0.02em;
      margin-bottom: var(--space-lg);
    }

    .event-hero__info {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .event-hero__info-row {
      display: flex;
      gap: var(--space-md);
      align-items: baseline;
    }

    .event-hero__info-label {
      font-family: 'Space Mono', monospace;
      font-size: var(--label);
      letter-spacing: 0.08em;
      color: var(--text-disabled);
      text-transform: uppercase;
      min-width: 64px;
    }

    .event-hero__info-value {
      font-family: 'Space Grotesk', sans-serif;
      font-size: var(--body-sm);
      color: var(--text-primary);
    }

    .event-hero__cta { margin-top: var(--space-2xl); align-self: flex-start; }

    /* Right panel: program */
    .event-program {
      padding: var(--space-3xl);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: var(--space-2xl);
    }

    .program-section__title {
      font-family: 'Space Mono', monospace;
      font-size: var(--label);
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      text-transform: uppercase;
      margin-bottom: var(--space-md);
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--border);
    }

    /* Agenda items */
    .agenda-item {
      display: flex;
      gap: var(--space-lg);
      padding: var(--space-md) 0;
      border-bottom: 1px solid var(--border);
    }

    .agenda-item__time {
      font-family: 'Space Mono', monospace;
      font-size: var(--body-sm);
      color: var(--text-secondary);
      min-width: 80px;
      flex-shrink: 0;
    }

    .agenda-item__content {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .agenda-item__title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: var(--subheading);
      font-weight: 500;
      color: var(--text-display);
    }

    .agenda-item__desc {
      font-family: 'Space Grotesk', sans-serif;
      font-size: var(--body-sm);
      color: var(--text-secondary);
      line-height: 1.5;
    }

    .agenda-item__speaker {
      font-family: 'Space Mono', monospace;
      font-size: var(--label);
      letter-spacing: 0.04em;
      color: var(--text-disabled);
      text-transform: uppercase;
      margin-top: 2px;
    }

    /* Sponsors & guests */
    .sponsor-grid {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    .sponsor-item {
      display: flex;
      align-items: baseline;
      gap: var(--space-md);
      padding: var(--space-sm) 0;
      border-bottom: 1px solid var(--border);
    }

    .sponsor-item__name {
      font-family: 'Space Grotesk', sans-serif;
      font-size: var(--body-sm);
      font-weight: 500;
      color: var(--text-primary);
      flex: 1;
    }

    .sponsor-item__role {
      font-family: 'Space Mono', monospace;
      font-size: var(--label);
      letter-spacing: 0.04em;
      color: var(--text-disabled);
      text-transform: uppercase;
    }

    /* Guest list */
    .guest-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .guest {
      display: flex;
      align-items: baseline;
      gap: var(--space-md);
      padding: var(--space-xs) 0;
    }

    .guest__name {
      font-family: 'Space Grotesk', sans-serif;
      font-size: var(--body-sm);
      color: var(--text-primary);
    }

    .guest__org {
      font-family: 'Space Mono', monospace;
      font-size: var(--label);
      letter-spacing: 0.04em;
      color: var(--text-disabled);
      text-transform: uppercase;
    }

    /* Mobile: vertical scroll */
    @media (max-width: 900px) {
      .event-page {
        display: flex;
        flex-direction: column;
      }

      .event-hero {
        border-right: none;
        border-bottom: 1px solid var(--border);
        padding: calc(var(--space-2xl) + 44px) var(--space-lg) var(--space-2xl);
        min-height: 60vh;
      }

      .event-hero__back {
        position: fixed;
        top: max(var(--space-md), env(safe-area-inset-top));
        left: var(--space-md);
        z-index: 100;
      }

      .event-hero__date { font-size: 80px; }
      .event-hero__year { font-size: 36px; }

      .event-program {
        padding: var(--space-lg);
      }
    }

    /* Page toolbar */
    .page-toolbar {
      position: fixed;
      top: 8px;
      right: 8px;
      z-index: 100;
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      padding: var(--space-xs);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 999px;
    }
    .theme-toggle {
      display: flex; align-items: center; gap: var(--space-sm);
      background: none; border: none; cursor: pointer; padding: var(--space-xs);
    }
    .theme-toggle__track {
      display: block; width: 36px; height: 18px;
      background: var(--surface-raised); border: 1px solid var(--border-visible);
      border-radius: 999px; position: relative;
      transition: background 200ms cubic-bezier(0.25, 0.1, 0.25, 1);
    }
    .theme-toggle__knob {
      display: block; width: 12px; height: 12px;
      background: var(--text-display); border-radius: 50%;
      position: absolute; top: 2px; left: 2px;
      transition: transform 200ms cubic-bezier(0.25, 0.1, 0.25, 1);
    }
    [data-theme="light"] .theme-toggle__knob { transform: translateX(18px); }
    .theme-toggle__label {
      font-family: 'Space Mono', monospace; font-size: var(--label);
      letter-spacing: 0.1em; color: var(--text-disabled); text-transform: uppercase;
    }

    /* Arrow chip & pill — shared with main site */
    .arrow-chip {
      width: 40px; height: 40px; border-radius: 50%;
      border: 1px solid var(--border-visible);
      background: var(--surface-raised);
      color: var(--text-display);
      font-family: 'Space Mono', monospace;
      font-size: var(--subheading); line-height: 1;
      display: inline-flex; align-items: center; justify-content: center;
      cursor: pointer; text-decoration: none; padding: 0;
      transition: background 180ms cubic-bezier(0.25,0.1,0.25,1),
                  color 180ms cubic-bezier(0.25,0.1,0.25,1),
                  border-color 180ms cubic-bezier(0.25,0.1,0.25,1);
    }
    .arrow-chip:hover {
      background: var(--text-display); color: var(--black);
      border-color: var(--text-display);
    }
    .arrow-pill {
      display: inline-flex; align-items: center; gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
      border: 1px solid var(--border-visible); border-radius: 999px;
      background: var(--surface-raised); color: var(--text-display);
      font-family: 'Space Mono', monospace;
      font-size: var(--body-sm); letter-spacing: 0.06em;
      text-transform: uppercase; text-decoration: none; cursor: pointer;
      transition: background 180ms cubic-bezier(0.25,0.1,0.25,1),
                  color 180ms cubic-bezier(0.25,0.1,0.25,1),
                  border-color 180ms cubic-bezier(0.25,0.1,0.25,1);
    }
    .arrow-pill:hover {
      background: var(--text-display); color: var(--black);
      border-color: var(--text-display);
    }
    .arrow-pill--accent { color: var(--accent); border-color: var(--accent); }
    .arrow-pill--accent:hover { background: var(--accent); color: var(--black); border-color: var(--accent); }
    .arrow-pill__arrow {
      font-size: var(--subheading); line-height: 1;
      transition: transform 200ms cubic-bezier(0.25,0.1,0.25,1);
    }
    .arrow-pill:hover .arrow-pill__arrow { transform: translateX(4px); }
    .arrow-chip:focus-visible,
    .arrow-pill:focus-visible { outline: 2px solid var(--interactive); outline-offset: 2px; }

    /* Mobile: bigger tap targets + safe-area */
    @media (max-width: 768px) {
      .arrow-chip { width: 44px; height: 44px; }
      .arrow-pill { padding: 10px var(--space-md); }
    }

    /* Focus */
    a:focus-visible, button:focus-visible {
      outline: 2px solid var(--interactive);
      outline-offset: 2px;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        transition-duration: 0ms !important;
      }
    }
  </style>
{% endblock %}

{% block body %}

  <div class="page-toolbar" role="toolbar" aria-label="Display settings">
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark and light mode" title="Toggle theme">
      <span class="theme-toggle__track">
        <span class="theme-toggle__knob"></span>
      </span>
      <span class="theme-toggle__label" aria-hidden="true">DARK</span>
    </button>
  </div>

  {% set ev = event.page %}
  {% set chipStyle = "font-family: 'Space Mono', monospace; font-size: var(--label); letter-spacing: 0.04em; color: var(--text-disabled); padding: 4px 10px; border: 1px solid var(--border-visible); border-radius: 999px;" %}

  <div class="event-page">

    <!-- Left: Hero -->
    <div class="event-hero">
      <a href="{{ ev.backHref }}" class="event-hero__back arrow-chip" aria-label="{{ ev.backLabel | h }}">&lt;</a>
      <div class="event-hero__label">{{ ev.label | h }}</div>
      <div class="event-hero__date">{{ ev.date | h }}</div>
      <div class="event-hero__year">{{ ev.year | h }}</div>
      <div class="event-hero__info">
{%- for row in ev.info %}
        <div class="event-hero__info-row">
          <span class="event-hero__info-label">{{ row.label | h }}</span>
          <span class="event-hero__info-value">{{ row.value | h }}</span>
        </div>
{%- endfor %}
      </div>
      <a href="{{ ev.cta.href }}" target="_blank" rel="noopener noreferrer" class="event-hero__cta arrow-pill arrow-pill--{{ ev.cta.variant }}">
        <span>{{ ev.cta.text | h }}</span>
        <span class="arrow-pill__arrow">→</span>
      </a>
    </div>

    <!-- Right: Program -->
    <div class="event-program">

      <div class="program-section">
        <div class="program-section__title">PROGRAM</div>
{%- for item in ev.program %}
        <div class="agenda-item">
          <span class="agenda-item__time">{{ item.time | h }}</span>
          <div class="agenda-item__content">
            <span class="agenda-item__title">{{ item.title | h }}</span>
            <span class="agenda-item__desc">{{ item.description | h }}</span>
            <span class="agenda-item__speaker">{{ item.speaker | h }}</span>
          </div>
        </div>
{%- endfor %}
      </div>

      <div class="program-section">
        <div class="program-section__title">FEATURED PRESENTATIONS</div>
        <div class="guest-list">
{%- for guest in ev.featured %}
          <div class="guest">
            <span class="guest__name">{{ guest.name | h }}</span>
            <span class="guest__org">{{ guest.org | h }}</span>
          </div>
{%- endfor %}
        </div>
      </div>

      <div class="program-section">
        <div class="program-section__title">SPONSORS</div>
        <div class="sponsor-grid">
{%- for s in ev.sponsors %}
          <div class="sponsor-item">
            <span class="sponsor-item__name">{{ s.name | h }}</span>
            <span class="sponsor-item__role">{{ s.role | h }}</span>
          </div>
{%- endfor %}
        </div>
      </div>

      <div class="program-section">
        <div class="program-section__title">PARTICIPATING ORGANIZATIONS</div>
        <div class="guest-list" style="flex-direction: row; flex-wrap: wrap; gap: 8px;">
{%- for org in ev.organizations %}
          <span style="{{ chipStyle }}">{{ org | h }}</span>
{%- endfor %}
        </div>
      </div>

    </div>

  </div>

  <script>
    (function() {
      var toggle = document.getElementById('themeToggle');
      var html = document.documentElement;
      var label = toggle.querySelector('.theme-toggle__label');
      var saved = localStorage.getItem('cim-theme');
      if (saved === 'light') { html.setAttribute('data-theme', 'light'); label.textContent = 'LIGHT'; }
      toggle.addEventListener('click', function() {
        var current = html.getAttribute('data-theme');
        var next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        label.textContent = next.toUpperCase();
        localStorage.setItem('cim-theme', next);
      });
    })();
  </script>
{% endblock %}
