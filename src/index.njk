{% extends "layout.njk" %}

{% set title = "CIM — Center for Interactive Media · Kennesaw State University" %}
{% set description = "Kennesaw State University's Center for Interactive Media — Game Studio, Digital Twin, XR Healthcare, Immersive Education, and Digital Humanities research." %}

{% block head %}
  <link rel="stylesheet" href="styles.css">
  <script>
    // Prevent FOUC: apply saved theme before first paint
    (function(){
      var t=localStorage.getItem('cim-theme');if(t)document.documentElement.setAttribute('data-theme',t);
    })();
  </script>
{% endblock %}

{% block body %}

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Page-level toolbar: theme -->
  <div class="page-toolbar" role="toolbar" aria-label="Display settings">
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark and light mode" title="Toggle theme">
      <span class="theme-toggle__track">
        <span class="theme-toggle__knob"></span>
      </span>
      <span class="theme-toggle__label" aria-hidden="true">DARK</span>
    </button>
  </div>

  <main id="main-content" class="bento-grid">

    <!-- FIXED: HERO -->
    {% include "components/hero.njk" %}

    <!-- ROTATING: SPOTLIGHT A — RESEARCH (5 slides) -->
    {% set spot = "research" %}
    {% set spotData = spotlights.research %}
    {% include "components/spotlight.njk" %}

    <!-- FIXED: LAUNCH EVENT -->
    {% include "components/launch-event-tile.njk" %}

    <!-- ROTATING: SPOTLIGHT B — SHOWCASE (6 slides) -->
    {% set spot = "showcase" %}
    {% set spotData = spotlights.showcase %}
    {% include "components/spotlight.njk" %}

    <!-- ROTATING: TOUCHPOINT (3 slides) -->
    {% set spot = "touchpoint" %}
    {% set spotData = spotlights.touchpoint %}
    {% include "components/spotlight.njk" %}

  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <span class="footer-clusters">GAME STUDIO · DIGITAL TWIN · XR &amp; HEALTHCARE · IMMERSIVE ED · DIGITAL HUMANITIES</span>
      <span class="footer-links">
        <a href="accessibility.html">ACCESSIBILITY</a>
      </span>
      <span class="footer-copy">&copy; 2026 Center for Interactive Media, Kennesaw State University</span>
    </div>
  </footer>

  <script>
    // Theme toggle
    (function() {
      var toggle = document.getElementById('themeToggle');
      var html = document.documentElement;
      var label = toggle.querySelector('.theme-toggle__label');

      var saved = localStorage.getItem('cim-theme');
      if (saved === 'light') {
        html.setAttribute('data-theme', 'light');
        label.textContent = 'LIGHT';
      }

      toggle.addEventListener('click', function() {
        var current = html.getAttribute('data-theme');
        var next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        label.textContent = next === 'light' ? 'LIGHT' : 'DARK';
        localStorage.setItem('cim-theme', next);
      });

      // Post-event state
      var eventTile = document.querySelector('.tile-event');
      if (eventTile) {
        var eventDate = new Date('2026-04-27T23:59:59');
        if (new Date() > eventDate) eventTile.classList.add('tile-event--past');
      }
    })();
  </script>

  <!-- Spotlight carousel controller -->
  <script src="spotlight.js" defer></script>
{% endblock %}
