{% extends "layout.njk" %}

{% set title = "JPA — JagoPakaiAI · Hub SKILL.MD, DESIGN.MD & MCP untuk AI Agent Indonesia" %}
{% set description = "Hub SKILL.MD, DESIGN.MD & MCP untuk AI Agent Indonesia. Otomatisasi konfigurasi AI Agent dengan 1-click via JPA CLI." %}

{% block head %}
  <link rel="stylesheet" href="styles.css">
  <script>
    // Prevent FOUC: apply saved theme before first paint
    (function(){
      var t=localStorage.getItem('jpa-theme');if(t)document.documentElement.setAttribute('data-theme',t);
    })();
  </script>
{% endblock %}

{% block body %}

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Page-level toolbar: theme -->
  <div class="page-toolbar" role="toolbar" aria-label="Display settings">
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark and light mode" title="Toggle theme">
      <span class="theme-toggle__track">
        <span class="theme-toggle__knob"></span>
      </span>
      <span class="theme-toggle__label" aria-hidden="true">DARK</span>
    </button>
  </div>

  <main id="main-content" class="bento-grid">

    <!-- FIXED: HERO -->
    {% include "components/hero.njk" %}

    <!-- ROTATING: SPOTLIGHT A — BLOG SLIDER -->
    {% set spot = "blog-slider" %}
    {% include "components/spotlight.njk" %}

    <!-- FIXED: JPA CLI INSTALL TILE -->
    {% include "components/install-tile.njk" %}

    <!-- FIXED: DIRECTORY SLIDER -->
    {% include "components/directory-spotlight.njk" %}

    <!-- ROTATING: TOUCHPOINT -->
    {% set spot = "touchpoint" %}
    {% set spotData = spotlights.touchpoint %}
    {% include "components/spotlight.njk" %}

  </main>

  <!-- Footer -->
  {% set footerLinks = [{ href: "jpacli.html", label: "JPA CLI" }, { href: "skills.html", label: "SKILL.MD" }, { href: "blog.html", label: "BLOG" }] %}
  {% include "components/footer.njk" %}

  <script>
    // Theme toggle
    (function() {
      var toggle = document.getElementById('themeToggle');
      var html = document.documentElement;
      var label = toggle.querySelector('.theme-toggle__label');

      var saved = localStorage.getItem('jpa-theme');
      if (saved === 'light') {
        html.setAttribute('data-theme', 'light');
        label.textContent = 'LIGHT';
      }

      toggle.addEventListener('click', function() {
        var current = html.getAttribute('data-theme');
        var next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        label.textContent = next === 'light' ? 'LIGHT' : 'DARK';
        localStorage.setItem('jpa-theme', next);
      });
    })();
  </script>

  <!-- Spotlight carousel controller -->
  <script src="spotlight.js" defer></script>
  <script src="directory-slider.js" defer></script>
{% endblock %}
