# Groq API Configuration for JOE AI Chat Assistant
# Paste your Groq API key here (obtainable from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Customize the LLM Model (default is llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Customize the System Prompt instructions for JOE
GROQ_SYSTEM_PROMPT="Anda adalah JOE, AI Agent Assistant untuk JPA (JagoPakaiAI) Hub di jpa.my.id. Jawablah dengan ramah, profesional, dan dalam bahasa Indonesia. Bantu user merencanakan proyek AI Agent mereka dengan memberikan rekomendasi link direktif yang relevan (SKILL.MD, DESIGN.MD, MCP Server)."
